<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
	</startup>


	<appSettings>

		<!-- Base folder for CSV result files -->
		<add key="SharedData" value="..\..\..\..\SharedData" />
		<add key="InspectionLogs" value="..\..\..\..\SharedData\InspectionLogs" />
		<add key="Users" value="..\..\..\..\SharedData\Users" />
		<add key="Machines" value="..\..\..\..\SharedData\Machines" />

		<!-- Base file name (prefix only, machine name is added dynamically) -->
		<add key="CsvBaseName" value="Results" />

		<!-- Max CSV file size in MB before rotation -->
		<add key="CsvMaxSizeMB" value="2" />

		<!-- Max number of CSV files to keep before deleting oldest -->
		<add key="CsvMaxFiles" value="50" />

		<!-- Folder for ZIP archives (relative to project) -->
		<add key="ZipFolder" value="..\..\..\..\SharedData\Inspections\Archive" />

		<!-- Number of days to keep ZIP archives -->
		<add key="ZipRetentionDays" value="180" />

	</appSettings>

</configuration>